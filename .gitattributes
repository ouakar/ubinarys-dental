# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare JS files to use LF
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.env* text eol=lf

# Explicitly declare binary files to not be touched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.ico binary
