{
  "name": "ubinarys-root",
  "version": "1.0.0",
  "scripts": {
    "install:all": "cd app/backend && npm install && cd ../frontend && npm install",
    "setup": "cd app/backend && npm run setup",
    "dev:backend": "cd app/backend && npm run dev",
    "dev:frontend": "cd app/frontend && npm run dev",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
