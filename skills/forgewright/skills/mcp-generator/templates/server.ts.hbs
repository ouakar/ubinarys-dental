// ─── File & Search Tools ────────────────────────────────────────

server.tool(
  "project_navigate",
  "Read file content from the project. Optionally specify line range.",
  {
    path: z.string().describe("Relative path from project root"),
    startLine: z.number().optional().describe("Start line (1-indexed)"),
    endLine: z.number().optional().describe("End line (1-indexed, inclusive)"),
  },
  async ({ path, startLine, endLine }) => {
    const content = readProjectFile(path);
    if (!content.startsWith("{") && startLine && endLine) {
      const lines = content.split("\n").slice(startLine - 1, endLine);
      return {
        content: [{ type: "text", text: lines.join("\n") }],
      };
    }
    return { content: [{ type: "text", text: content }] };
  }
);

server.tool(
  "project_search",
  "Fast text search across the project using ripgrep.",
  {
    pattern: z.string().describe("Search pattern (regex supported)"),
    includes: z
      .array(z.string())
      .optional()
      .describe("Glob patterns to filter files, e.g. ['*.ts', '*.tsx']"),
  },
  async ({ pattern, includes }) => {
    const result = ripgrepSearch(pattern, includes || []);
    return { content: [{ type: "text", text: result }] };
  }
);

// ─── Action / Write Tools (V2) ──────────────────────────────────

server.tool(
  "project_write_file",
  "Write or overwrite a file in the project workspace. Max 512KB per write.",
  {
    path: z.string().describe("Relative path from project root"),
    content: z.string().describe("Full content to write to the file"),
  },
  async ({ path, content }) => {
    try {
      validatePath(path);
      if (Buffer.byteLength(content, "utf-8") > WRITE_MAX_BYTES) {
        throw new Error(`Content exceeds ${WRITE_MAX_BYTES} byte limit.`);
      }
      const fullPath = join(PROJECT_ROOT, path);
      mkdirSync(dirname(fullPath), { recursive: true });
      writeFileSync(fullPath, content, "utf-8");
      return { content: [{ type: "text", text: `✓ Wrote ${Buffer.byteLength(content)} bytes to ${path}` }] };
    } catch (e: any) {
      return { content: [{ type: "text", text: `Failed to write file: ${e.message}` }] };
    }
  }
);

server.tool(
  "project_git_status",
  "Get the current git status of the project.",
  {},
  async () => {
    try {
      const output = execSync(`git status`, { cwd: PROJECT_ROOT, encoding: "utf-8" });
      return { content: [{ type: "text", text: output }] };
    } catch (e: any) {
      return { content: [{ type: "text", text: e.stdout || e.message }] };
    }
  }
);

server.tool(
  "project_run_script",
  "Run an npm script from those defined in package.json. Only scripts detected at generation time are allowed.",
  {
    script: z.string().describe("The npm script name to run (must exist in package.json)"),
  },
  async ({ script }) => {
    try {
      const allowed = getDetectedScripts();
      if (allowed.length > 0 && !allowed.includes(script)) {
        return { content: [{ type: "text", text: `Script "${script}" not found in package.json. Available: ${allowed.join(", ")}` }] };
      }
      const output = execSync(`npm run ${script}`, {
        cwd: PROJECT_ROOT,
        encoding: "utf-8",
        timeout: 120000,
        stdio: ["pipe", "pipe", "pipe"],
      });
      return { content: [{ type: "text", text: output }] };
    } catch (error: any) {
      return { content: [{ type: "text", text: error.stdout || error.message }] };
    }
  }
);

