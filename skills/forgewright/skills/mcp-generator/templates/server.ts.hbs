// Ensure MCP server operates from the project root
process.chdir(PROJECT_ROOT);

// ─── Helpers ────────────────────────────────────────────────────

const WRITE_MAX_BYTES = 512 * 1024; // 512 KB max per write

function validatePath(relativePath: string): void {
  if (relativePath.includes("..")) {
    throw new Error("Path traversal (..) is not allowed.");
  }
  const normalized = relativePath.replace(/\\/g, "/");
  if (normalized.startsWith(".git") || normalized.includes("/.git")) {
    throw new Error("Access to .git directory is forbidden.");
  }
  const basename = normalized.split("/").pop() || "";
  if (basename === ".env" || basename.startsWith(".env.")) {
    throw new Error("Access to .env files is forbidden.");
  }
}

function getDetectedScripts(): string[] {
  try {
    const pkgPath = join(PROJECT_ROOT, "package.json");
    if (!existsSync(pkgPath)) return [];
    const pkg = JSON.parse(readFileSync(pkgPath, "utf-8"));
    return Object.keys(pkg.scripts || {});
  } catch {
    return [];
  }
}

function readProjectFile(relativePath: string): string {
  try {
    validatePath(relativePath);
    const fullPath = join(PROJECT_ROOT, relativePath);
    if (!existsSync(fullPath)) {
      return JSON.stringify({ error: `File not found: ${relativePath}` });
    }
    return readFileSync(fullPath, "utf-8");
  } catch (e: any) {
    return JSON.stringify({ error: e.message });
  }
}

function ripgrepSearch(pattern: string, includes: string[] = []): string {
  try {
    const includeArgs = includes.map((g) => `--glob=${g}`).join(" ");
    return execSync(
      `rg --json --max-count=50 ${includeArgs} ${JSON.stringify(pattern)} .`,
      {
        cwd: PROJECT_ROOT,
        encoding: "utf-8",
        timeout: 10000,
        stdio: ["pipe", "pipe", "pipe"],
      }
    ).trim();
  } catch {
    return JSON.stringify({ matches: [], error: "Search returned no results or failed" });
  }
}

function formatResult(result: any): string {
  if (typeof result === "string") return result;
  return JSON.stringify(result, null, 2);
}

// ─── Server Setup ───────────────────────────────────────────────

const server = new McpServer({
  name: "{{projectName}}",
  version: "2.0.0",
  capabilities: {
